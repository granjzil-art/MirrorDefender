[gd_resource type="Resource" script_class="LevelResource" format=3]

[ext_resource type="Script" path="res://scripts/level/LevelResource.gd" id="1_level"]
[ext_resource type="Script" path="res://scripts/path/PathDefinition.gd" id="2_path"]
[ext_resource type="Script" path="res://scripts/path/SpawnPointDefinition.gd" id="3_spawn"]
[ext_resource type="Script" path="res://scripts/wave/SpawnGroupDefinition.gd" id="4_group"]
[ext_resource type="Script" path="res://scripts/wave/WaveDefinition.gd" id="5_wave"]
[ext_resource type="Resource" path="res://resources/enemies/Grunt.tres" id="6_grunt"]
[ext_resource type="Resource" path="res://resources/enemies/Runner.tres" id="7_runner"]

[sub_resource type="Resource" id="Path_Main"]
script = ExtResource("2_path")
path_id = &"main"
display_name = "中央进攻路线"
cells = Array[Vector3i]([Vector3i(-4, 0, 4), Vector3i(-3, 0, 3), Vector3i(-2, 0, 2), Vector3i(-1, 0, 1), Vector3i(0, 0, 0), Vector3i(1, 0, -1), Vector3i(2, 0, -2), Vector3i(3, 0, -3), Vector3i(4, 0, -4)])

[sub_resource type="Resource" id="Spawn_North"]
script = ExtResource("3_spawn")
spawn_id = &"north"
display_name = "北侧入口"
cell = Vector3i(-4, 0, 4)

[sub_resource type="Resource" id="Group_One"]
script = ExtResource("4_group")
enemy = ExtResource("6_grunt")
count = 4
interval = 0.6
spawn_point = SubResource("Spawn_North")
path = SubResource("Path_Main")

[sub_resource type="Resource" id="Wave_One"]
script = ExtResource("5_wave")
display_name = "第 1 波：步兵侦察"
spawn_groups = Array[ExtResource("4_group")]([SubResource("Group_One")])

[sub_resource type="Resource" id="Group_Two_A"]
script = ExtResource("4_group")
enemy = ExtResource("6_grunt")
count = 5
interval = 0.45
spawn_point = SubResource("Spawn_North")
path = SubResource("Path_Main")

[sub_resource type="Resource" id="Group_Two_B"]
script = ExtResource("4_group")
enemy = ExtResource("7_runner")
count = 3
interval = 0.8
start_delay = 1.0
spawn_point = SubResource("Spawn_North")
path = SubResource("Path_Main")

[sub_resource type="Resource" id="Wave_Two"]
script = ExtResource("5_wave")
display_name = "第 2 波：混编突击"
spawn_groups = Array[ExtResource("4_group")]([SubResource("Group_Two_A"), SubResource("Group_Two_B")])

[resource]
script = ExtResource("1_level")
grid_shape = 0
grid_cell_size = 1.0
grid_size = Vector2i(6, 6)
initial_resource = 500
building_cap = 20
mirror_cap = 6
base_resource_per_second = 1.0
base_cell = Vector3i(4, 0, -4)
base_max_hp = 100.0
paths = Array[ExtResource("2_path")]([SubResource("Path_Main")])
spawn_points = Array[ExtResource("3_spawn")]([SubResource("Spawn_North")])
waves = Array[ExtResource("5_wave")]([SubResource("Wave_One"), SubResource("Wave_Two")])
wave_prep_time = 1.0
